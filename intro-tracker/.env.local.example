# Auth
AUTH_PASSWORD_HASH=
SESSION_SECRET=dev-secret

# Sentry (optional locally — leave blank to disable)
# Real values live in Fly secrets: `fly secrets set SENTRY_DSN=... NEXT_PUBLIC_SENTRY_DSN=...`
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source-map upload (only needed in CI / production builds)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Litestream (production only — set via `fly secrets set ...`)
# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=
# LITESTREAM_BUCKET=
# LITESTREAM_ENDPOINT=
# LITESTREAM_REGION=auto
# LITESTREAM_PATH=crm.db
