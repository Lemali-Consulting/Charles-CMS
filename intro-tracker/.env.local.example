# Auth (magic-link via Auth.js + Resend)

# Random string used to sign JWT session tokens. Generate with `openssl rand -base64 32`.
AUTH_SECRET=

# Canonical origin of the deployed app (e.g. https://charles-cms.fly.dev).
# Must match where the magic-link redirects to; required in production.
AUTH_URL=http://localhost:3000

# Resend API key (https://resend.com/api-keys).
AUTH_RESEND_KEY=

# "From" address for magic-link emails. Domain must be verified in Resend.
# Example: Charles CMS <noreply@yourdomain.com>
AUTH_EMAIL_FROM=

# Comma-separated list of email addresses allowed to sign in. Empty = deny all.
# Example: charles@example.com,max@example.com
AUTH_ALLOWED_EMAILS=

# Sentry (optional locally — leave blank to disable)
# Real values live in Fly secrets: `fly secrets set SENTRY_DSN=... NEXT_PUBLIC_SENTRY_DSN=...`
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source-map upload (only needed in CI / production builds)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Litestream → Tigris (production only)
# These are injected automatically by `fly storage create`:
# BUCKET_NAME=
# AWS_ENDPOINT_URL_S3=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
