# Auth
AUTH_PASSWORD_HASH=
SESSION_SECRET=dev-secret

# Sentry (optional locally — leave blank to disable)
# Real values live in Fly secrets: `fly secrets set SENTRY_DSN=... NEXT_PUBLIC_SENTRY_DSN=...`
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source-map upload (only needed in CI / production builds)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Litestream → Tigris (production only)
# These are injected automatically by `fly storage create`:
# BUCKET_NAME=
# AWS_ENDPOINT_URL_S3=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
